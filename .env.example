# Copy this file to `.env` and fill in your local values.
# Never commit real API keys, brokerage credentials, or production passwords.

# Security
HFFI_AUTH_ENABLED=true
HFFI_SECRET_KEY=replace-with-a-long-random-secret
HFFI_TOKEN_TTL_MINUTES=480
HFFI_ADMIN_USERNAME=admin
HFFI_ADMIN_PASSWORD=change-me-now
# Optional role accounts
HFFI_ANALYST_USERNAME=
HFFI_ANALYST_PASSWORD=
HFFI_VIEWER_USERNAME=
HFFI_VIEWER_PASSWORD=
HFFI_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# FRED macro data. Optional: the app can use fallback data without a key.
FRED_API_KEY=

# NewsAPI market news. Optional.
NEWSAPI_KEY=

# Optional: Polygon.io. Required only if MARKET_PROVIDER=polygon.
POLYGON_API_KEY=

# Optional: Alpaca market data. Use paper credentials only for experiments.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# Provider selection: yfinance | polygon | alpaca
MARKET_PROVIDER=yfinance

# Universe selection: sp500 | russell1000 | full_us | custom
TICKER_UNIVERSE=sp500
